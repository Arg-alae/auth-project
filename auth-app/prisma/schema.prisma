generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  password          String
  refreshToken      String?
  isVerified        Boolean   @default(false)
  verificationToken String?
  resetToken        String?    // ← token de réinitialisation
  resetTokenExpiry  DateTime?  // ← expiration du token (1 heure)
  createdAt         DateTime  @default(now())
  products          Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float?
  imageUrl    String?
  images      String[]
  sku         String?  @unique
  stock       Int      @default(0)
  status      String   @default("draft")
  isActive    Boolean  @default(false)
  category    String?
  tags        String[]
  weight      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}